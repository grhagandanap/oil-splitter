# ── Database (PostgreSQL via Docker) ──────────────────────────────────────────
POSTGRES_USER=oilsplitter
POSTGRES_PASSWORD=oilsplitter_password
POSTGRES_DB=oilsplitter_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Connection string used by the FastAPI backend (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://oilsplitter:oilsplitter_password@localhost:5433/oilsplitter_db

# ── FastAPI ────────────────────────────────────────────────────────────────────
ENV=dev
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend (Vite / TanStack Start) ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
